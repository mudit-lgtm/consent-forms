<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a8a"/>
      <stop offset="60%" style="stop-color:#1d4ed8"/>
      <stop offset="100%" style="stop-color:#3b82f6"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="60" y="60" width="1080" height="510" rx="16" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
  
  <!-- Logo icon -->
  <rect x="100" y="110" width="56" height="56" rx="10" fill="#1d4ed8"/>
  <rect x="113" y="124" width="30" height="4" rx="2" fill="white"/>
  <rect x="113" y="133" width="30" height="4" rx="2" fill="white"/>
  <rect x="113" y="142" width="20" height="4" rx="2" fill="white"/>
  <circle cx="148" cy="158" r="8" fill="#059669"/>
  <polyline points="144,158 147,161 153,155" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>

  <!-- Title -->
  <text x="175" y="152" font-family="system-ui,-apple-system,sans-serif" font-size="28" font-weight="800" fill="white">InterviewConsentForms</text>
  
  <!-- Main heading -->
  <text x="100" y="260" font-family="system-ui,-apple-system,sans-serif" font-size="62" font-weight="900" fill="white">Interview Consent Forms</text>
  
  <!-- Subtitle -->
  <text x="100" y="320" font-family="system-ui,-apple-system,sans-serif" font-size="28" fill="rgba(255,255,255,0.85)">Free Create, Fill &amp; Download | PDF &amp; Word</text>
  
  <!-- Badges -->
  <rect x="100" y="365" width="145" height="40" rx="20" fill="rgba(255,255,255,0.15)"/>
  <text x="172" y="390" font-family="system-ui,-apple-system,sans-serif" font-size="16" font-weight="700" fill="white" text-anchor="middle">✓ 100% Free</text>
  
  <rect x="260" y="365" width="190" height="40" rx="20" fill="rgba(255,255,255,0.15)"/>
  <text x="355" y="390" font-family="system-ui,-apple-system,sans-serif" font-size="16" font-weight="700" fill="white" text-anchor="middle">✓ No Sign-Up</text>
  
  <rect x="465" y="365" width="230" height="40" rx="20" fill="rgba(255,255,255,0.15)"/>
  <text x="580" y="390" font-family="system-ui,-apple-system,sans-serif" font-size="16" font-weight="700" fill="white" text-anchor="middle">✓ PDF &amp; Word Download</text>
  
  <rect x="710" y="365" width="230" height="40" rx="20" fill="rgba(255,255,255,0.15)"/>
  <text x="825" y="390" font-family="system-ui,-apple-system,sans-serif" font-size="16" font-weight="700" fill="white" text-anchor="middle">✓ IRB-Compliant</text>
  
  <!-- CTA Button -->
  <rect x="100" y="440" width="320" height="60" rx="10" fill="#059669"/>
  <text x="260" y="477" font-family="system-ui,-apple-system,sans-serif" font-size="22" font-weight="700" fill="white" text-anchor="middle">Create Form Free →</text>
  
  <!-- URL -->
  <text x="100" y="540" font-family="system-ui,-apple-system,sans-serif" font-size="20" fill="rgba(255,255,255,0.6)">consentforms.vercel.app</text>
</svg>